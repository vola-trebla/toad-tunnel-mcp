{
  "name": "toad-tunnel-mcp",
  "version": "0.1.1",
  "description": "Multi-environment PostgreSQL MCP router with SSH tunnel management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "toad-tunnel-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "config/toad-tunnel.example.yaml",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vola-trebla/toad-tunnel-mcp.git"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "node dist/index.js validate",
    "sandbox:up": "docker compose -f sandbox/docker-compose.yml up -d",
    "sandbox:down": "docker compose -f sandbox/docker-compose.yml down",
    "sandbox:reset": "docker compose -f sandbox/docker-compose.yml down -v && docker compose -f sandbox/docker-compose.yml up -d",
    "sandbox:logs": "docker compose -f sandbox/docker-compose.yml logs -f",
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "*.{ts,json,md,yml,yaml}": "prettier --write"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "postgresql",
    "postgres",
    "ssh-tunnel",
    "multi-env",
    "database",
    "ai-tools"
  ],
  "author": "vola-trebla",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pg": "^8.20.0",
    "ssh2": "^1.17.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/ssh2": "^1.15.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
