{
  "name": "toad-tunnel-mcp",
  "version": "0.1.0",
  "description": "Multi-environment PostgreSQL MCP router with SSH tunnel management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "toad-tunnel-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "sandbox:up": "docker compose -f sandbox/docker-compose.yml up -d",
    "sandbox:down": "docker compose -f sandbox/docker-compose.yml down",
    "sandbox:reset": "docker compose -f sandbox/docker-compose.yml down -v && docker compose -f sandbox/docker-compose.yml up -d",
    "sandbox:logs": "docker compose -f sandbox/docker-compose.yml logs -f",
    "sandbox:verify": "npm run sandbox:wait && vitest run sandbox/verify.test.ts",
    "sandbox:wait": "until docker compose -f sandbox/docker-compose.yml exec -T postgres pg_isready -U toad -d postgres > /dev/null 2>&1; do sleep 1; done",
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "*.{ts,json,md,yml,yaml}": "prettier --write"
  },
  "keywords": [
    "mcp",
    "postgresql",
    "ssh-tunnel",
    "multi-env"
  ],
  "author": "vola-trebla",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pg": "^8.20.0",
    "ssh2": "^1.17.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/ssh2": "^1.15.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
